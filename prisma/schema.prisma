// Rebate Management System - Database Schema
// See docs/SYSTEM_DESIGN.md Section 5 for design rationale.
//
// Key relationships:
//   Distributor -> Contract (scoped to end user) -> Rebate Plan -> Rebate Record <- Item
//
// Rebate ID in the spreadsheet = distributor code (e.g., "FAS" = Fastenal).
// One contract per end user, unique to a distributor.
// rebatePrice = deviated price (the approved contract price per unit, e.g., $2.78).
// See docs/RECONCILIATION_DESIGN.md Section 10 for pricing model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// DISTRIBUTORS (called "Rebate ID" or "Customer ID" in spreadsheets)
// ---------------------------------------------------------------------------
// Primary business entity. The rebate is paid to the distributor.
// Examples: FAS (Fastenal), MOTION, HSC, AIT, LGG, TIPCO
model Distributor {
  id               Int        @id @default(autoincrement())
  code             String     @unique @db.VarChar(50) // Business key: FAS, HSC, MOTION
  name             String     @db.VarChar(255)        // Display name: Fastenal, Motion Industries
  externalCrmId    String?    @map("external_crm_id") @db.VarChar(100)
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  contracts             Contract[]
  reconciliationRuns    ReconciliationRun[]
  claimBatches          ClaimBatch[]
  posBatches            PosBatch[]
  columnMappings        DistributorColumnMapping[]

  @@map("distributors")
}

// ---------------------------------------------------------------------------
// END USERS
// ---------------------------------------------------------------------------
// The end user is the reason the rebate exists — "we rebate Fastenal because
// they sell to Link-Belt." One contract per end user per distributor.
model EndUser {
  id               Int        @id @default(autoincrement())
  code             String     @unique @db.VarChar(50) // Business key
  name             String     @db.VarChar(255)
  externalCrmId    String?    @map("external_crm_id") @db.VarChar(100)
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  contracts        Contract[]

  @@map("end_users")
}

// ---------------------------------------------------------------------------
// CONTRACTS
// ---------------------------------------------------------------------------
// One contract per distributor + end user combination.
// Example: Contract 101700 = Fastenal selling to Link-Belt (specifically OSW products)
model Contract {
  id               Int          @id @default(autoincrement())
  distributorId    Int          @map("distributor_id")
  endUserId        Int          @map("end_user_id")
  contractNumber   String       @map("contract_number") @db.VarChar(100)
  customerNumber   String?      @map("customer_number") @db.VarChar(100) // Distributor location/branch account number
  description      String?      @db.VarChar(500)
  contractType     String       @default("fixed_term") @map("contract_type") @db.VarChar(20) // fixed_term, evergreen
  startDate        DateTime?    @map("start_date") @db.Date
  endDate          DateTime?    @map("end_date") @db.Date
  noticePeriodDays Int?         @map("notice_period_days") // Termination notice period for evergreen contracts
  status           String       @default("pending_review") @db.VarChar(20) // pending_review, active, expired, cancelled
  lastReviewedAt   DateTime?    @map("last_reviewed_at") // Manual or auto-updated on contract update commit
  externalErpId    String?      @map("external_erp_id") @db.VarChar(100)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  distributor      Distributor  @relation(fields: [distributorId], references: [id])
  endUser          EndUser      @relation(fields: [endUserId], references: [id])
  rebatePlans      RebatePlan[]
  updateRuns       ContractUpdateRun[]

  @@unique([distributorId, endUserId, contractNumber])
  @@index([distributorId])
  @@index([endUserId])
  @@map("contracts")
}

// ---------------------------------------------------------------------------
// REBATE PLANS
// ---------------------------------------------------------------------------
// A rebate program within a contract. Plan ID from spreadsheet (e.g., "OSW").
// Discount type is exclusive: 'part' or 'product_code', never both.
model RebatePlan {
  id               Int            @id @default(autoincrement())
  contractId       Int            @map("contract_id")
  planCode         String         @map("plan_code") @db.VarChar(100) // Business key: OSW, etc.
  planName         String?        @map("plan_name") @db.VarChar(255)
  discountType     String         @map("discount_type") @db.VarChar(20) // 'part' or 'product_code'
  status           String         @default("active") @db.VarChar(20) // active, expired, cancelled
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  contract         Contract       @relation(fields: [contractId], references: [id])
  rebateRecords    RebateRecord[]

  @@unique([contractId, planCode])
  @@map("rebate_plans")
}

// ---------------------------------------------------------------------------
// ITEMS
// ---------------------------------------------------------------------------
// Part numbers / SKUs. Shared across all distributors.
// Example: 0304-C-04
model Item {
  id               Int            @id @default(autoincrement())
  itemNumber       String         @unique @map("item_number") @db.VarChar(100)
  description      String?        @map("item_description") @db.VarChar(500)
  productCode      String?        @map("product_code") @db.VarChar(100) // Category grouping
  externalErpId    String?        @map("external_erp_id") @db.VarChar(100)
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  rebateRecords    RebateRecord[]

  @@index([productCode])
  @@map("items")
}

// ---------------------------------------------------------------------------
// REBATE RECORDS
// ---------------------------------------------------------------------------
// The core table. Each row: "For this plan + item, this rebate price applies
// during this date range."
// Example: Plan OSW, Item 0304-C-04, $0.30/unit, 11/1/2023 - 12/31/2026
model RebateRecord {
  id               Int            @id @default(autoincrement())
  rebatePlanId     Int            @map("rebate_plan_id")
  itemId           Int            @map("item_id")
  rebatePrice      Decimal        @map("rebate_price") @db.Decimal(12, 4)
  startDate        DateTime       @map("start_date") @db.Date
  endDate          DateTime?      @map("end_date") @db.Date
  status           String         @default("active") @db.VarChar(20)
  // Versioning chain
  supersededById   Int?           @unique @map("superseded_by_id")
  supersededBy     RebateRecord?  @relation("SupersessionChain", fields: [supersededById], references: [id])
  supersedes       RebateRecord?  @relation("SupersessionChain")
  // Tracking
  importBatchId    Int?           @map("import_batch_id")
  createdById      Int            @map("created_by_id")
  updatedById      Int            @map("updated_by_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  rebatePlan       RebatePlan     @relation(fields: [rebatePlanId], references: [id])
  item             Item           @relation(fields: [itemId], references: [id])
  importBatch      ImportBatch?   @relation(fields: [importBatchId], references: [id])
  createdBy        User           @relation("RecordCreatedBy", fields: [createdById], references: [id])
  updatedBy        User           @relation("RecordUpdatedBy", fields: [updatedById], references: [id])
  notes            RecordNote[]

  @@unique([rebatePlanId, itemId, startDate])
  @@index([rebatePlanId, itemId])
  @@index([status])
  @@index([importBatchId])
  @@map("rebate_records")
}

// ---------------------------------------------------------------------------
// RECORD NOTES
// ---------------------------------------------------------------------------
// Replaces the "Comment" column with timestamped, attributed notes.
model RecordNote {
  id               Int          @id @default(autoincrement())
  rebateRecordId   Int          @map("rebate_record_id")
  noteType         String       @default("general") @map("note_type") @db.VarChar(50)
  noteText         String       @map("note_text")
  createdById      Int          @map("created_by_id")
  createdAt        DateTime     @default(now()) @map("created_at")

  rebateRecord     RebateRecord @relation(fields: [rebateRecordId], references: [id])
  createdBy        User         @relation(fields: [createdById], references: [id])

  @@index([rebateRecordId])
  @@map("record_notes")
}

// ---------------------------------------------------------------------------
// AUDIT LOG
// ---------------------------------------------------------------------------
// Immutable, append-only. Every write on business tables generates an entry.
// See docs/SYSTEM_DESIGN.md Appendix C for format specification.
model AuditLog {
  id               BigInt       @id @default(autoincrement())
  tableName        String       @map("table_name") @db.VarChar(100)
  recordId         Int          @map("record_id")
  action           String       @db.VarChar(20) // INSERT, UPDATE, DELETE
  changedFields    Json         @map("changed_fields") @db.JsonB
  userId           Int          @map("user_id")
  ipAddress        String?      @map("ip_address") @db.VarChar(45)
  createdAt        DateTime     @default(now()) @map("created_at")

  user             User         @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// IMPORT BATCHES
// ---------------------------------------------------------------------------
// Tracks every spreadsheet import for traceability.
model ImportBatch {
  id               Int            @id @default(autoincrement())
  fileName         String         @map("file_name") @db.VarChar(500)
  fileHash         String?        @map("file_hash") @db.VarChar(128)
  distributorId    Int?           @map("distributor_id")
  totalRows        Int            @default(0) @map("total_rows")
  importedCount    Int            @default(0) @map("imported_count")
  skippedCount     Int            @default(0) @map("skipped_count")
  errorCount       Int            @default(0) @map("error_count")
  status           String         @default("pending") @db.VarChar(20)
  importedById     Int            @map("imported_by_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  completedAt      DateTime?      @map("completed_at")

  importedBy       User           @relation(fields: [importedById], references: [id])
  rebateRecords    RebateRecord[]

  @@map("import_batches")
}

// ---------------------------------------------------------------------------
// USERS
// ---------------------------------------------------------------------------
model User {
  id               Int            @id @default(autoincrement())
  username         String         @unique @db.VarChar(100)
  displayName      String         @map("display_name") @db.VarChar(255)
  email            String         @db.VarChar(255)
  passwordHash     String         @map("password_hash") @db.VarChar(255)
  role             String         @db.VarChar(50) // admin, rebate_manager, viewer
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  auditLogs             AuditLog[]
  recordNotes           RecordNote[]
  importBatches         ImportBatch[]
  createdRecords        RebateRecord[] @relation("RecordCreatedBy")
  updatedRecords        RebateRecord[] @relation("RecordUpdatedBy")
  reconciliationRuns    ReconciliationRun[]
  claimBatches          ClaimBatch[]
  posBatches            PosBatch[]            @relation("PosUploadedBy")
  resolvedIssues        ReconciliationIssue[] @relation("IssueResolvedBy")
  contractUpdateRuns    ContractUpdateRun[]    @relation("UpdateRunUploadedBy")
  committedUpdateRuns   ContractUpdateRun[]    @relation("UpdateRunCommittedBy")
  resolvedDiffs         ContractUpdateDiff[]  @relation("DiffResolvedBy")

  @@map("users")
}

// ---------------------------------------------------------------------------
// RECONCILIATION RUNS
// ---------------------------------------------------------------------------
// Tracks each monthly claim validation execution.
// See docs/RECONCILIATION_DESIGN.md Section 9.1 for design rationale.
model ReconciliationRun {
  id                Int       @id @default(autoincrement())
  distributorId     Int       @map("distributor_id")
  claimPeriodStart  DateTime  @map("claim_period_start") @db.Date
  claimPeriodEnd    DateTime  @map("claim_period_end") @db.Date
  status            String    @default("draft") @db.VarChar(20) // draft, staged, running, review, completed, cancelled
  claimBatchId      Int?      @unique @map("claim_batch_id")
  posBatchId        Int?      @unique @map("pos_batch_id")
  totalClaimLines   Int       @default(0) @map("total_claim_lines")
  validatedCount    Int       @default(0) @map("validated_count")
  exceptionCount    Int       @default(0) @map("exception_count")
  approvedCount     Int       @default(0) @map("approved_count")
  rejectedCount     Int       @default(0) @map("rejected_count")
  approvedAmount    Decimal?  @map("approved_amount") @db.Decimal(12, 4)
  rejectedAmount    Decimal?  @map("rejected_amount") @db.Decimal(12, 4)
  commitSummary     Json?     @map("commit_summary")   // Persisted at commit time: { recordsCreated, recordsSuperseded, recordsUpdated, itemsCreated, confirmed, rejected, dismissed, deferred, totalApproved }
  runById           Int       @map("run_by_id")
  startedAt         DateTime  @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")

  distributor       Distributor @relation(fields: [distributorId], references: [id])
  claimBatch        ClaimBatch? @relation(fields: [claimBatchId], references: [id])
  posBatch          PosBatch?   @relation(fields: [posBatchId], references: [id])
  runBy             User        @relation(fields: [runById], references: [id])
  issues            ReconciliationIssue[]

  @@index([distributorId])
  @@index([status])
  @@map("reconciliation_runs")
}

// ---------------------------------------------------------------------------
// CLAIM BATCHES
// ---------------------------------------------------------------------------
// Tracks uploaded distributor claim files (monthly).
model ClaimBatch {
  id                Int       @id @default(autoincrement())
  distributorId     Int       @map("distributor_id")
  claimPeriodStart  DateTime  @map("claim_period_start") @db.Date
  claimPeriodEnd    DateTime  @map("claim_period_end") @db.Date
  fileName          String    @map("file_name") @db.VarChar(500)
  fileHash          String?   @map("file_hash") @db.VarChar(128)
  totalRows         Int       @default(0) @map("total_rows")
  validRows         Int       @default(0) @map("valid_rows")
  errorRows         Int       @default(0) @map("error_rows")
  status            String    @default("uploaded") @db.VarChar(20) // uploaded, parsed, staged, error
  columnMapping     String    @default("") @map("column_mapping") @db.VarChar(50) // distributor code used for mapping
  uploadedById      Int       @map("uploaded_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  distributor       Distributor        @relation(fields: [distributorId], references: [id])
  uploadedBy        User               @relation(fields: [uploadedById], references: [id])
  rows              ClaimRow[]
  reconciliationRun ReconciliationRun?

  @@index([distributorId])
  @@map("claim_batches")
}

// ---------------------------------------------------------------------------
// CLAIM ROWS
// ---------------------------------------------------------------------------
// Individual parsed claim lines from a distributor's monthly claim file.
// All fields nullable because they come from external data that may be incomplete.
model ClaimRow {
  id                      Int       @id @default(autoincrement())
  batchId                 Int       @map("batch_id")
  rowNumber               Int       @map("row_number")
  // Mapped standard fields
  contractNumber          String?   @map("contract_number") @db.VarChar(100)
  planCode                String?   @map("plan_code") @db.VarChar(100)
  itemNumber              String?   @map("item_number") @db.VarChar(100)
  distributorItemNumber   String?   @map("distributor_item_number") @db.VarChar(100)
  endUserCode             String?   @map("end_user_code") @db.VarChar(100)
  endUserName             String?   @map("end_user_name") @db.VarChar(255)
  transactionDate         DateTime? @map("transaction_date") @db.Date
  standardPrice           Decimal?  @map("standard_price") @db.Decimal(12, 4)
  deviatedPrice           Decimal?  @map("deviated_price") @db.Decimal(12, 4)
  quantity                Decimal?  @db.Decimal(12, 4)
  claimedAmount           Decimal?  @map("claimed_amount") @db.Decimal(12, 4)
  distributorOrderNumber  String?   @map("distributor_order_number") @db.VarChar(100)
  // Traceability
  rawData                 Json      @map("raw_data") @db.JsonB
  parseErrors             Json?     @map("parse_errors") @db.JsonB
  matchedRecordId         Int?      @map("matched_record_id")
  status                  String    @default("parsed") @db.VarChar(20) // parsed, validated, unmatched, error

  batch                   ClaimBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([contractNumber, itemNumber])
  @@map("claim_rows")
}

// ---------------------------------------------------------------------------
// POS BATCHES
// ---------------------------------------------------------------------------
// Tracks uploaded distributor POS (Point of Sale) reports.
// POS data is supplementary — used for cross-referencing claims, not proof.
model PosBatch {
  id                Int       @id @default(autoincrement())
  distributorId     Int       @map("distributor_id")
  periodStart       DateTime  @map("period_start") @db.Date
  periodEnd         DateTime  @map("period_end") @db.Date
  fileName          String    @map("file_name") @db.VarChar(500)
  totalRows         Int       @default(0) @map("total_rows")
  validRows         Int       @default(0) @map("valid_rows")
  errorRows         Int       @default(0) @map("error_rows")
  status            String    @default("uploaded") @db.VarChar(20) // uploaded, parsed, error
  columnMapping     String    @default("") @map("column_mapping") @db.VarChar(50)
  uploadedById      Int       @map("uploaded_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  distributor       Distributor        @relation(fields: [distributorId], references: [id])
  uploadedBy        User               @relation("PosUploadedBy", fields: [uploadedById], references: [id])
  rows              PosRow[]
  reconciliationRun ReconciliationRun?

  @@index([distributorId])
  @@map("pos_batches")
}

// ---------------------------------------------------------------------------
// POS ROWS
// ---------------------------------------------------------------------------
// Individual parsed rows from a distributor's POS report.
model PosRow {
  id                      Int       @id @default(autoincrement())
  batchId                 Int       @map("batch_id")
  rowNumber               Int       @map("row_number")
  // Mapped standard fields
  itemNumber              String?   @map("item_number") @db.VarChar(100)
  distributorItemNumber   String?   @map("distributor_item_number") @db.VarChar(100)
  transactionDate         DateTime? @map("transaction_date") @db.Date
  quantity                Decimal?  @db.Decimal(12, 4)
  sellPrice               Decimal?  @map("sell_price") @db.Decimal(12, 4)
  extendedAmount          Decimal?  @map("extended_amount") @db.Decimal(12, 4)
  endUserCode             String?   @map("end_user_code") @db.VarChar(100)
  endUserName             String?   @map("end_user_name") @db.VarChar(255)
  orderNumber             String?   @map("order_number") @db.VarChar(100)
  shipToCity              String?   @map("ship_to_city") @db.VarChar(100)
  shipToState             String?   @map("ship_to_state") @db.VarChar(50)
  // Traceability
  rawData                 Json      @map("raw_data") @db.JsonB
  parseErrors             Json?     @map("parse_errors") @db.JsonB
  status                  String    @default("parsed") @db.VarChar(20) // parsed, matched, unmatched

  batch                   PosBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([itemNumber, transactionDate])
  @@map("pos_rows")
}

// ---------------------------------------------------------------------------
// RECONCILIATION ISSUES
// ---------------------------------------------------------------------------
// Exceptions detected during a claim validation run.
// See docs/RECONCILIATION_DESIGN.md Section 6 for exception categories.
model ReconciliationIssue {
  id                    Int       @id @default(autoincrement())
  reconciliationRunId   Int       @map("reconciliation_run_id")
  code                  String    @db.VarChar(20)  // CLM-001 through CLM-014
  severity              String    @db.VarChar(20)  // error, warning, info
  category              String    @db.VarChar(100)  // Human-readable category
  description           String    @db.Text          // Specific description with values
  claimRowId            Int?      @map("claim_row_id")
  masterRecordId        Int?      @map("master_record_id") // Matched rebate_record if applicable
  suggestedAction       String    @map("suggested_action") @db.VarChar(50)  // approve, reject, adjust, update_contract, flag_review, create_item
  suggestedData         Json?     @map("suggested_data") @db.JsonB
  // Resolution
  resolution            String?   @db.VarChar(50)  // approved, rejected, adjusted, deferred, dismissed
  resolutionNote        String?   @map("resolution_note") @db.Text
  resolvedById          Int?      @map("resolved_by_id")
  resolvedAt            DateTime? @map("resolved_at")
  committedRecordId     Int?      @map("committed_record_id") // If resolution created/updated a contract record

  reconciliationRun     ReconciliationRun @relation(fields: [reconciliationRunId], references: [id], onDelete: Cascade)
  resolvedBy            User?             @relation("IssueResolvedBy", fields: [resolvedById], references: [id])

  @@index([reconciliationRunId])
  @@index([code])
  @@index([resolution])
  @@map("reconciliation_issues")
}

// ---------------------------------------------------------------------------
// DISTRIBUTOR COLUMN MAPPINGS
// ---------------------------------------------------------------------------
// Per-distributor configuration for how their file columns map to standard
// system fields. Supports both claim files and contract files.
// Users configure these via the Settings UI by uploading a sample file.
model DistributorColumnMapping {
  id               Int       @id @default(autoincrement())
  distributorId    Int       @map("distributor_id")
  fileType         String    @default("claim") @map("file_type") @db.VarChar(20) // claim, contract, pos
  name             String    @db.VarChar(255) // Display name: "Fastenal Claim File"
  // The mapping: standard field name → distributor column header (JSON object)
  mappings         Json      @db.JsonB
  dateFormat       String    @default("M/d/yyyy") @map("date_format") @db.VarChar(50)
  skipColumns      Json?     @map("skip_columns") @db.JsonB // Array of column names to ignore
  sampleHeaders    Json?     @map("sample_headers") @db.JsonB // Detected headers from sample file
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  distributor      Distributor @relation(fields: [distributorId], references: [id])

  @@unique([distributorId, fileType])
  @@map("distributor_column_mappings")
}

// ---------------------------------------------------------------------------
// CONTRACT UPDATE RUNS
// ---------------------------------------------------------------------------
// A contract update session: user uploads a file to update an existing contract.
// Analogous to ReconciliationRun but for contract modifications.
model ContractUpdateRun {
  id                Int       @id @default(autoincrement())
  contractId        Int       @map("contract_id")
  fileMode          String    @map("file_mode") @db.VarChar(20) // snapshot, delta
  fileName          String    @map("file_name") @db.VarChar(500)
  fileHash          String?   @map("file_hash") @db.VarChar(128)
  // Run-level effective date: user can set a single effective date for all changes
  effectiveDate     DateTime? @map("effective_date") @db.Date
  status            String    @default("staged") @db.VarChar(20) // staged, review, committed, cancelled
  totalRows         Int       @default(0) @map("total_rows")
  unchangedCount    Int       @default(0) @map("unchanged_count")
  changedCount      Int       @default(0) @map("changed_count")
  addedCount        Int       @default(0) @map("added_count")
  removedCount      Int       @default(0) @map("removed_count")
  commitSummary     Json?     @map("commit_summary") @db.JsonB
  runById           Int       @map("run_by_id")
  committedById     Int?      @map("committed_by_id") // User who committed (may differ from uploader)
  createdAt         DateTime  @default(now()) @map("created_at")
  committedAt       DateTime? @map("committed_at")

  contract          Contract  @relation(fields: [contractId], references: [id])
  runBy             User      @relation("UpdateRunUploadedBy", fields: [runById], references: [id])
  committedBy       User?     @relation("UpdateRunCommittedBy", fields: [committedById], references: [id])
  diffs             ContractUpdateDiff[]

  @@index([contractId])
  @@index([status])
  @@map("contract_update_runs")
}

// ---------------------------------------------------------------------------
// CONTRACT UPDATE DIFFS
// ---------------------------------------------------------------------------
// Individual diff rows — only actionable changes stored (not unchanged rows).
model ContractUpdateDiff {
  id                    Int       @id @default(autoincrement())
  runId                 Int       @map("run_id")
  diffType              String    @map("diff_type") @db.VarChar(20) // changed, added, removed
  // Item identity — normalized to itemId where possible
  itemId                Int?      @map("item_id")
  itemNumber            String    @map("item_number") @db.VarChar(100)
  // Plan matching
  rebatePlanId          Int?      @map("rebate_plan_id")
  planCode              String?   @map("plan_code") @db.VarChar(100)
  matchedRecordId       Int?      @map("matched_record_id")
  // What changed (for 'changed' diffs)
  oldPrice              Decimal?  @map("old_price") @db.Decimal(12, 4)
  newPrice              Decimal?  @map("new_price") @db.Decimal(12, 4)
  // Match confidence
  matchStatus           String    @default("auto") @map("match_status") @db.VarChar(20) // auto, ambiguous, manual
  ambiguityReason       String?   @map("ambiguity_reason") @db.VarChar(255)
  // Resolution (user decision — Phase C)
  resolution            String?   @db.VarChar(20) // apply, skip, modify
  resolutionData        Json?     @map("resolution_data") @db.JsonB
  resolvedById          Int?      @map("resolved_by_id")
  resolvedAt            DateTime? @map("resolved_at")
  // Commit result
  committedRecordId     Int?      @map("committed_record_id")

  run                   ContractUpdateRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  resolvedBy            User?             @relation("DiffResolvedBy", fields: [resolvedById], references: [id])

  @@index([runId])
  @@map("contract_update_diffs")
}
